
{% block nav %}
<nav>
    <button onclick="document.querySelector('.overlay').classList.toggle('open')">
        <svg viewBox="0 0 100 80" width="28" height="28" fill="none" stroke="currentColor" stroke-width="12" stroke-linecap="round">
            <rect width="100" height="16" rx="8" y="0"/>
            <rect width="100" height="16" rx="8" y="32"/>
            <rect width="100" height="16" rx="8" y="64"/>
        </svg>
    </button>
    <ul>
        <li><a href="{{ path('homepage') }}" class="cta">
            <img src="{{ asset('icon/homepageIcon.svg') }}" alt="Accueil">
            <span>Accueil</span>
        </a></li>
        <li><a href="{{ path('menus') }}" class="menu cta">
            <img src="{{ asset('icon/menusIcon.svg') }}" alt="Menus">
            <span>Menus</span>
        </a></li>
        <li><a href="{{ path('contact') }}" class="cta">
            <img src="{{ asset('icon/contactIcon.svg') }}" alt="Nous contacter">
            <span>Nous contacter</span>
        </a></li>
        <li><a href="{{ path('user') }}" class="cta">
            <img src="{{ asset('icon/userIcon.svg') }}" alt="Utilisateur">
            <span>Connexion</span>
        </a></li>
    </ul>
</nav>
{% endblock %}