{% extends 'employee/base.html.twig' %}
{% block title %}Nouveau plat{% endblock %}
{% block employee_body %}
    <h1>Nouveau plat</h1>
    <form method="post" enctype="multipart/form-data">
        <label>Titre
            <input type="text" name="title" required>
        </label>
        <label>Description
            <textarea name="description"></textarea>
        </label>
        <label>Photo
            <input type="file" name="photo" accept="image/*">
        </label>
        <label>Allergènes
            <select name="allergens[]" multiple>
                {% for allergen in allergens %}
                    <option value="{{ allergen.id }}">{{ allergen.label }}</option>
                {% endfor %}
            </select>
        </label>
        <button type="submit" class="cta">Créer</button>
    </form>
{% endblock %}
