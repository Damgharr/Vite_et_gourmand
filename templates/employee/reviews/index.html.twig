{% extends 'employee/base.html.twig' %}
{% block title %}Avis{% endblock %}
{% block employee_body %}
    <h1>Avis</h1>
    <form method="get">
        <select name="status">
            <option value="">Tous</option>
            <option value="en attente" {% if filter == 'en attente' %}selected{% endif %}>En attente</option>
            <option value="acceptée" {% if filter == 'acceptée' %}selected{% endif %}>Acceptée</option>
            <option value="refusée" {% if filter == 'refusée' %}selected{% endif %}>Refusée</option>
        </select>
        <button type="submit" class="cta">Filtrer</button>
    </form>
    <ul>
        {% for review in reviews %}
            <li>
                <p>{{ review.user.firstName }} {{ review.user.lastName }} — {{ review.note }}/5</p>
                <p>{{ review.text }}</p>
                <p>Statut : {{ review.status }}</p>
                <form method="post" action="{{ path('employee_reviews_status', {id: review.id}) }}">
                    <select name="status">
                        <option value="en attente" {% if review.status == 'en attente' %}selected{% endif %}>En attente</option>
                        <option value="acceptée" {% if review.status == 'acceptée' %}selected{% endif %}>Acceptée</option>
                        <option value="refusée" {% if review.status == 'refusée' %}selected{% endif %}>Refusée</option>
                    </select>
                    <button type="submit" class="cta">Modifier</button>
                </form>
            </li>
        {% endfor %}
    </ul>
{% endblock %}
