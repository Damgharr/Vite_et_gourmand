{% extends 'employee/base.html.twig' %}
{% block title %}Modifier menu{% endblock %}
{% block employee_body %}
    <h1>Modifier menu</h1>
    <form method="post">
        <label>Titre
            <input type="text" name="title" value="{{ menu.title }}" required>
        </label>
        <label>Description
            <textarea name="description">{{ menu.description }}</textarea>
        </label>
        <label>Personnes min
            <input type="number" name="minPeopleAmount" value="{{ menu.minPeopleAmount }}" required>
        </label>
        <label>Prix par personne
            <input type="number" step="0.01" name="pricePerPeople" value="{{ menu.pricePerPeople }}" required>
        </label>
        <label>Stock
            <input type="number" name="remaining" value="{{ menu.remaining }}" required>
        </label>
        <label>Thème
            <select name="theme" required>
                {% for theme in themes %}
                    <option value="{{ theme.id }}" {% if menu.theme.id == theme.id %}selected{% endif %}>{{ theme.label }}</option>
                {% endfor %}
            </select>
        </label>
        <label>Régime
            <select name="diet" required>
                {% for diet in diets %}
                    <option value="{{ diet.id }}" {% if menu.diet.id == diet.id %}selected{% endif %}>{{ diet.label }}</option>
                {% endfor %}
            </select>
        </label>
        <label>Plats
            <select name="dishes[]" multiple>
                {% for dish in dishes %}
                    <option value="{{ dish.id }}" {% if menu.dishes.contains(dish) %}selected{% endif %}>{{ dish.title }}</option>
                {% endfor %}
            </select>
        </label>
        <button type="submit" class="cta">Enregistrer</button>
    </form>
{% endblock %}
