{% for menu in menus %}
    <article data-menu="{{ {
        id: menu.id,
        title: menu.title,
        description: menu.description|default(''),
        theme: menu.theme.label,
        diet: menu.diet.label,
        remaining: menu.remaining,
        minPeopleAmount: menu.minPeopleAmount,
        pricePerPeople: menu.pricePerPeople,
        totalPrice: menu.totalPrice,
        dishes: menu.dishes|map(d => {
            id: d.id,
            title: d.title,
            description: d.description|default(''),
            photoUrl: path('dish_photo', {id: d.id}),
            allergens: d.allergens|map(a => a.label)
        })
    }|json_encode|e('html_attr') }}">
        <h2>{{ menu.title }}</h2>
        <p>{{ menu.description }}</p>
        <div>
            <span>{{ menu.theme.label }}</span>
            <span>{{ menu.diet.label }}</span>
        </div>
        <p>Minimum {{ menu.minPeopleAmount }} personnes</p>
        <p>{{ menu.pricePerPeople }} € / personne</p>
        <p>Total : {{ menu.totalPrice }} €</p>
        <button class="cta details-btn">Détails</button>
    </article>
{% endfor %}
