{% extends 'base.html.twig' %}
{% block title %}Nous contacter{% endblock %}
{% block stylesheets %} <link rel="stylesheet" href="{{ asset('css/contact.css') }}"> {% endblock %}
{% block body %}
<main>
    <h1>Nous contacter</h1>
    {% for message in app.flashes('success') %}
        <p class="flash success">{{ message }}</p>
    {% endfor %}
    {% if errors is defined %}
        <ul>
            {% for error in errors %}
                <li>{{ error }}</li>
            {% endfor %}
        </ul>
    {% endif %}
    <form method="post" action="{{ path('contact') }}">
        <label>Email
            <input type="email" name="email" value="{{ email|default('') }}" required>
        </label>
        <label>Sujet
            <input type="text" name="subject" value="{{ subject|default('') }}" required>
        </label>
        <label>Message
            <textarea name="content" rows="8" required>{{ content|default('') }}</textarea>
        </label>
        <button type="submit" class="cta">Envoyer</button>
    </form>
</main>
{% endblock %}
