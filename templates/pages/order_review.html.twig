{% extends 'base.html.twig' %}

{% block title %}Donner un avis — {{ order.orderNumber }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/profile.css') }}">
{% endblock %}

{% block body %}
    <main>
        <h1>Donner un avis — {{ order.orderNumber }}</h1>
        {% if errors is defined and errors|length > 0 %}
            <ul class="errors">
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        {% endif %}
        <form method="post" action="{{ path('profile_order_review', {id: order.id}) }}" class="review-form">
            <p>Menu : {{ order.menu.title }}</p>
            <label>Note
                <div class="star-rating">
                    {% for i in 5..1 %}
                        <input type="radio" name="note" id="star{{ i }}" value="{{ i }}" required>
                        <label for="star{{ i }}">★</label>
                    {% endfor %}
                </div>
            </label>
            <label>Commentaire (optionnel)
                <textarea name="text" rows="5"></textarea>
            </label>
            <div class="form-actions">
                <a href="{{ path('profile') }}" class="cta secondary">Annuler</a>
                <button type="submit" class="cta">Envoyer mon avis</button>
            </div>
        </form>
    </main>
{% endblock %}
