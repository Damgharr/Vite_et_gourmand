{% extends 'base.html.twig' %}
{% block title %}Inscription{% endblock %}
{% block body %}
<main>
    <h1>Inscription</h1>
    {% if errors is defined %}
        <ul>
            {% for error in errors %}
                <li>{{ error }}</li>
            {% endfor %}
        </ul>
    {% endif %}
    <form method="post" action="{{ path('app_register') }}">
        <label>Prénom
            <input type="text" name="firstName" value="{{ firstName|default('') }}" required>
        </label>
        <label>Nom
            <input type="text" name="lastName" value="{{ lastName|default('') }}" required>
        </label>
        <label>Téléphone
            <input type="text" name="phone" value="{{ phone|default('') }}" required>
        </label>
        <label>Email
            <input type="email" name="email" value="{{ email|default('') }}" required>
        </label>
        <label>Mot de passe
            <input type="password" name="password" required>
        </label>
        <label>Confirmer le mot de passe
            <input type="password" name="passwordConfirm" required>
        </label>
        <label>Pays
            <input type="text" name="country" value="{{ country|default('') }}">
        </label>
        <label>Ville
            <input type="text" name="city" value="{{ city|default('') }}">
        </label>
        <label>Code postal
            <input type="text" name="zipCode" value="{{ zipCode|default('') }}">
        </label>
        <label>Adresse
            <textarea name="adress">{{ adress|default('') }}</textarea>
        </label>
        <button type="submit" class="cta">S'inscrire</button>
    </form>
</main>
{% endblock %}
