{% extends 'admin/base.html.twig' %}
{% block title %}Thèmes{% endblock %}
{% block admin_body %}
    <h1>Thèmes</h1>
    <a href="{{ path('admin_themes_new') }}" class="cta">Nouveau thème</a>
    <ul>
        {% for theme in themes %}
            <li>
                {{ theme.label }}
                <a href="{{ path('admin_themes_edit', {id: theme.id}) }}">Modifier</a>
                <form method="post" action="{{ path('admin_themes_delete', {id: theme.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ theme.id) }}">
                    <button>Supprimer</button>
                </form>
            </li>
        {% endfor %}
    </ul>
{% endblock %}
