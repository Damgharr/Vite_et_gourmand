{% extends 'admin/base.html.twig' %}
{% block title %}Modifier plat{% endblock %}
{% block admin_body %}
    <h1>Modifier plat</h1>
    <form method="post" enctype="multipart/form-data">
        <label>Titre
            <input type="text" name="title" value="{{ dish.title }}" required>
        </label>
        <label>Description
            <textarea name="description">{{ dish.description }}</textarea>
        </label>
        <label>Photo
            <input type="file" name="photo" accept="image/*">
        </label>
        <label>Allergènes
            <select name="allergens[]" multiple>
                {% for allergen in allergens %}
                    <option value="{{ allergen.id }}" {% if dish.allergens.contains(allergen) %}selected{% endif %}>{{ allergen.label }}</option>
                {% endfor %}
            </select>
        </label>
        <button type="submit" class="cta">Enregistrer</button>
    </form>
{% endblock %}
